// ~/.config/niri/config.kdl — translated from the Hyprland binds.
// MODEL: niri is scrollable-tiling. Left/Right = between COLUMNS,
// Up/Down = between windows stacked IN a column. Workspaces are a vertical strip.
// Validate after edits:  niri validate

prefer-no-csd

input {
    keyboard {
        xkb {
            layout "us"
            variant "intl"
        }
    }
    touchpad { tap; natural-scroll; }
}

cursor {
    xcursor-theme "Bibata-Modern-Ice"
    xcursor-size 24
}

// Outputs left to niri's auto-handling (preferred mode, auto-arrange).
// eDP follows the lid: closed -> off (HDMI only), open -> on (HDMI + laptop).
switch-events {
    lid-close { spawn "niri" "msg" "output" "eDP-1" "off"; }
    lid-open  { spawn "niri" "msg" "output" "eDP-1" "on"; }
}

layout {
    gaps 8
    preset-column-widths { proportion 0.333; proportion 0.5; proportion 0.667; }
    default-column-width { proportion 0.5; }
    focus-ring { width 2; }
}

hotkey-overlay { skip-at-startup; }

// Rounded corners on all windows. clip-to-geometry is required, or only the
// border rounds and the window's square content corners poke through.
window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
}

// Static, ordered workspaces (Hyprland-style): declared in order so positions are
// fixed. 1–9 then "comms" → comms is the LAST one (position 10 = Mod+0). niri still
// appends one empty dynamic workspace after the last named one; you just won't use it.
workspace "1"
workspace "2"
workspace "3"
workspace "4"
workspace "5"
workspace "6"
workspace "7"
workspace "8"
workspace "9"
workspace "comms"

// Auto-open Discord + Obsidian there. Verify the app-ids with `niri msg windows`
// (Discord may report differently, esp. under XWayland).
window-rule {
    match app-id=r#"^vesktop$"#
    open-on-workspace "comms"
}
window-rule {
    match app-id=r#"^obsidian$"#
    open-on-workspace "comms"
}

// X11 apps: niri has no built-in XWayland — xwayland-satellite provides it.
environment { DISPLAY ":0"; }

spawn-at-startup "xwayland-satellite" ":0"
spawn-at-startup "qs" "-c" "noctalia-shell"  // Noctalia = a Quickshell config (/etc/xdg/quickshell/noctalia-shell)
spawn-at-startup "hypridle"
spawn-at-startup "hyprsunset"

binds {
    // ── apps / menus ──
    Mod+T { spawn "kitty"; }
    Mod+E { spawn "nautilus"; }
    Mod+A { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "toggle"; }   // verify: qs -c noctalia-shell ipc show
    Mod+W { spawn "/home/leotsgo/scripts/wifimenu"; }
    Mod+B { spawn "/home/leotsgo/scripts/bluetoothmenu"; }
    Mod+Shift+P { spawn "/home/leotsgo/scripts/powermenu"; }
    Mod+C { spawn "sh" "-c" "grim -g \"$(slurp)\" - | swappy -f -"; }
    Mod+Shift+L { spawn "hyprlock"; }                                    // works on niri (ext-session-lock)

    // ── window / session ──
    Mod+Q { close-window; }
    Mod+V { toggle-window-floating; }
    Mod+M { quit; }                                                      // add skip-confirmation=true for instant exit

    // ── focus (arrows → column model) ──
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }

    // ── workspaces 1–10 ──
    Mod+1 { focus-workspace "1"; }
    Mod+2 { focus-workspace "2"; }
    Mod+3 { focus-workspace "3"; }
    Mod+4 { focus-workspace "4"; }
    Mod+5 { focus-workspace "5"; }
    Mod+6 { focus-workspace "6"; }
    Mod+7 { focus-workspace "7"; }
    Mod+8 { focus-workspace "8"; }
    Mod+9 { focus-workspace "9"; }
    Mod+0 { focus-workspace "comms"; }
    Mod+Shift+1 { move-column-to-workspace "1"; }
    Mod+Shift+2 { move-column-to-workspace "2"; }
    Mod+Shift+3 { move-column-to-workspace "3"; }
    Mod+Shift+4 { move-column-to-workspace "4"; }
    Mod+Shift+5 { move-column-to-workspace "5"; }
    Mod+Shift+6 { move-column-to-workspace "6"; }
    Mod+Shift+7 { move-column-to-workspace "7"; }
    Mod+Shift+8 { move-column-to-workspace "8"; }
    Mod+Shift+9 { move-column-to-workspace "9"; }
    Mod+Shift+0 { move-column-to-workspace "comms"; }

    // ── Super+scroll → workspace switch ──
    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp   cooldown-ms=150 { focus-workspace-up; }

    // ── media / volume / brightness (work while locked) ──
    XF86AudioRaiseVolume allow-when-locked=true { spawn "wpctl" "set-volume" "-l" "1" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    XF86AudioMute        allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"; }
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "-e4" "-n2" "set" "5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "-e4" "-n2" "set" "5%-"; }
    XF86AudioNext  allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPlay  allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPause allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev  allow-when-locked=true { spawn "playerctl" "previous"; }

    // ── niri-native essentials (no Hyprland equivalent, but you'll want them) ──
    Mod+R { switch-preset-column-width; }            // cycle column width — *the* niri move
    Mod+F { maximize-column; }
    Mod+P { fullscreen-window; }                     // repurposed from dwindle pseudo
    Mod+Comma  { consume-window-into-column; }        // pull next window into this column
    Mod+Period { expel-window-from-column; }
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Right { move-column-right; }
}
